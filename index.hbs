{{> head}}
{{> header}}

<main class="site-main">

    {{!-- Hero --}}
    <section class="hero-smartweb surface-muted padding-b-0">
        <div class="container text-center">
            <div class="grid-12">
                <div class="md-col-6-centered text-center">
                    <h1 class="h2">
                        {{#if @config.custom.homeHeroTitle}}
                            {{@config.custom.homeHeroTitle}}
                        {{else}}
                            SmartWebsite
                        {{/if}}
                    </h1>
                    <h2 class="h4 subtitle">Conversion System</h2>
                    <a class="button button--xl button--link"
                        href="{{@website.baseUrl}}from-inquiry-to-payment-where-businesses-lose-money-every-day">
                        Learn More
                    </a>
                    <a class="button button--xl" href="{{@website.baseUrl}}smartweb">Buy Now</a>
                </div>
            </div>
            <div class="grid-12">
                <figure class="md-col-10-centered text-center padding-t-xl">
                    <img src="{{asset "images/conversation-system.svg"}}" alt="SmartWebsite Conversion System diagram">
                </figure>
            </div>
        </div>
    </section>

    {{!-- Services --}}
    <section class="order-form-section" id="final-cta">
        <div class="you-need-help">
            <header class="you-need-help__header">
                <h2 class="padding-b-xl">Get AI Help</h2>
                <h3 class="subtitle">Your Business Needs</h3>
            </header>
            <ul class="grid-12">
                <li class="card md-col-4 lg-col-5 card--left items-end">
                    <div class="card-wraper-left">
                        <span class="you-need-help__number" aria-hidden="true">01</span>
                        <div class="you-need-help__body">
                            <h3 class="you-need-help__name">Sell More</h3>
                            <p class="you-need-help__desc">Improve customer conversations and conversion</p>
                            <a class="you-need-help__link" href="{{@website.baseUrl}}pages/sell-more.html">
                                Learn More
                                <svg class="you-need-help__link-icon" viewBox="0 0 16 16" aria-hidden="true" focusable="false">
                                    <path fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" d="M3 13 L13 3 M6 3 H13 V10" />
                                </svg>
                            </a>
                        </div>
                        <div class="you-need-help__art" aria-hidden="true">
                            <img class="service-icon" src="{{asset "images/chat.svg"}}" alt="">
                        </div>
                    </div>
                </li>
                <li class="card md-col-4 lg-col-2 card--dark">
                    <span class="you-need-help__number" aria-hidden="true">02</span>
                    <div class="you-need-help__body">
                        <h3 class="you-need-help__name">Save Time</h3>
                        <p class="you-need-help__desc">Reduce repetitive work and speed up execution</p>
                        <a class="you-need-help__link" href="{{@website.baseUrl}}pages/save-time.html">
                            Learn More
                            <svg class="you-need-help__link-icon" viewBox="0 0 16 16" aria-hidden="true" focusable="false">
                                <path fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" d="M3 13 L13 3 M6 3 H13 V10" />
                            </svg>
                        </a>
                    </div>
                    <div class="you-need-help__art" aria-hidden="true">
                        <img class="service-icon" src="{{asset "images/clock.svg"}}" alt="">
                    </div>
                </li>
                <li class="card md-col-4 lg-col-5 card--accent">
                    <div class="card-wraper-rigth lg-col-2">
                        <span class="you-need-help__number" aria-hidden="true">03</span>
                        <div class="you-need-help__body">
                            <h3 class="you-need-help__name">Run Better</h3>
                            <p class="you-need-help__desc">Improve workflows and business operations</p>
                            <a class="you-need-help__link" href="{{@website.baseUrl}}pages/run-better.html">
                                Learn More
                                <svg class="you-need-help__link-icon" viewBox="0 0 16 16" aria-hidden="true" focusable="false">
                                    <path fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" d="M3 13 L13 3 M6 3 H13 V10" />
                                </svg>
                            </a>
                        </div>
                        <div class="you-need-help__art max-heigh" aria-hidden="true">
                            <img class="service-icon" src="{{asset "images/crog.svg"}}" alt="">
                        </div>
                    </div>
                </li>
            </ul>
        </div>
    </section>

    {{!-- Feature Post — latest published post from any tag --}}
    <section class="feature-post padding-0" data-lab-feature>
        {{#each posts}}
            {{#checkIf @index "==" 0}}
                <div class="whatsnew">
                    <figure class="whatsnew__figure">
                        {{#featuredImage}}
                            <img src="{{url}}" alt="{{alt}}" class="whatsnew__image" />
                        {{else}}
                            <img src="{{asset "images/swimming-pool-beach-hotel-resort.jpg"}}" alt="" class="whatsnew__image" />
                        {{/featuredImage}}
                    </figure>
                    <div class="whatsnew__overlay">
                        <div class="container">
                            <div class="grid-12 items-middle">
                                <div class="lg-col-7 md-col-12 whatsnew__spacer"></div>
                                <div class="whatsnew__content lg-col-4 md-col-12 stack stack--lg">
                                    {{#if mainTag}}
                                        <span class="tag">{{mainTag.name}}</span>
                                    {{else}}
                                        <span class="tag">Latest</span>
                                    {{/if}}
                                    <h3 class="whatsnew__heading">{{title}}</h3>
                                    <a href="{{url}}" class="whatsnew__link">
                                        Learn More
                                        <svg class="whatsnew__link-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
                                            <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
                                            <polyline points="15 3 21 3 21 9"></polyline>
                                            <line x1="10" y1="14" x2="21" y2="3"></line>
                                        </svg>
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            {{/checkIf}}
        {{/each}}
    </section>

    {{!-- Lab Insights — 3 category tabs pulling live posts by tag slug --}}
    <section class="section just-published" id="lab-insights" aria-labelledby="lab-insights-title">
        <div class="container lab-insights">
            <header class="lab-insights__header">
                <h2 class="display-l lab-insights__title" id="lab-insights-title">The Lab Insights</h2>
                <div class="lab-insights__tabs" role="tablist" aria-label="Filter insights by category">
                    <button class="lab-insights__tab is-active" type="button" role="tab"
                        aria-selected="true" data-tab="all">All</button>
                    <button class="lab-insights__tab" type="button" role="tab"
                        aria-selected="false" data-tab="revenue-conversion">Revenue Growth</button>
                    <button class="lab-insights__tab" type="button" role="tab"
                        aria-selected="false" data-tab="workflow-automation">Team Productivity</button>
                    <button class="lab-insights__tab" type="button" role="tab"
                        aria-selected="false" data-tab="business-operations">Business Operations</button>
                </div>
            </header>

            <ul class="lab-insights__track" role="list" data-lab-track>

                {{!-- Revenue Growth posts (tag: revenue-conversion) --}}
                {{#getPostsByTags "count=5&allowed=published&orderby=createdAt&ordering=desc&tag_as=slug&tags=revenue-conversion"}}
                    <li class="lab-card" data-lab-card data-category="revenue-conversion">
                        <a class="lab-card__media" href="{{url}}" aria-label="{{title}}">
                            {{#featuredImage}}
                                <img src="{{url}}" alt="{{alt}}" loading="lazy" />
                            {{else}}
                                <img src="{{asset "images/chatbot_laptop.png"}}" alt="{{title}}" loading="lazy" />
                            {{/featuredImage}}
                        </a>
                        <div class="lab-card__panel">
                            <div class="lab-card__content">
                                <span class="lab-card__meta">
                                    <span class="lab-card__category">Revenue Growth</span>
                                    <span class="lab-card__sep" aria-hidden="true"></span>
                                    <time class="lab-card__read" datetime="{{date createdAt "YYYY-MM-DD"}}">
                                        {{date createdAt "MMM D, YYYY"}}
                                    </time>
                                </span>
                                <h3 class="lab-card__title"><a href="{{url}}">{{title}}</a></h3>
                                {{#if postViewConfig.articleExcerpt}}
                                    <p class="lab-card__excerpt">{{postViewConfig.articleExcerpt}}</p>
                                {{/if}}
                                <a class="lab-card__cta" href="{{url}}">
                                    Read More
                                    <svg class="lab-card__cta-icon" viewBox="0 0 16 16" aria-hidden="true" focusable="false">
                                        <path fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" d="M3 8h10 M9 4l4 4-4 4" />
                                    </svg>
                                </a>
                            </div>
                        </div>
                    </li>
                {{/getPostsByTags}}

                {{!-- Team Productivity posts (tag: workflow-automation) --}}
                {{#getPostsByTags "count=5&allowed=published&orderby=createdAt&ordering=desc&tag_as=slug&tags=workflow-automation"}}
                    <li class="lab-card" data-lab-card data-category="workflow-automation">
                        <a class="lab-card__media" href="{{url}}" aria-label="{{title}}">
                            {{#featuredImage}}
                                <img src="{{url}}" alt="{{alt}}" loading="lazy" />
                            {{else}}
                                <img src="{{asset "images/developer_workspace.png"}}" alt="{{title}}" loading="lazy" />
                            {{/featuredImage}}
                        </a>
                        <div class="lab-card__panel">
                            <div class="lab-card__content">
                                <span class="lab-card__meta">
                                    <span class="lab-card__category">Workflow Automation</span>
                                    <span class="lab-card__sep" aria-hidden="true"></span>
                                    <time class="lab-card__read" datetime="{{date createdAt "YYYY-MM-DD"}}">
                                        {{date createdAt "MMM D, YYYY"}}
                                    </time>
                                </span>
                                <h3 class="lab-card__title"><a href="{{url}}">{{title}}</a></h3>
                                {{#if postViewConfig.articleExcerpt}}
                                    <p class="lab-card__excerpt">{{postViewConfig.articleExcerpt}}</p>
                                {{/if}}
                                <a class="lab-card__cta" href="{{url}}">
                                    Read More
                                    <svg class="lab-card__cta-icon" viewBox="0 0 16 16" aria-hidden="true" focusable="false">
                                        <path fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" d="M3 8h10 M9 4l4 4-4 4" />
                                    </svg>
                                </a>
                            </div>
                        </div>
                    </li>
                {{/getPostsByTags}}

                {{!-- Business Operations posts --}}
                {{#getPostsByTags "count=5&allowed=published&orderby=createdAt&ordering=desc&tag_as=slug&tags=business-operations"}}
                    <li class="lab-card" data-lab-card data-category="business-operations">
                        <a class="lab-card__media" href="{{url}}" aria-label="{{title}}">
                            {{#featuredImage}}
                                <img src="{{url}}" alt="{{alt}}" loading="lazy" />
                            {{else}}
                                <img src="{{asset "images/boutique_shopping.png"}}" alt="{{title}}" loading="lazy" />
                            {{/featuredImage}}
                        </a>
                        <div class="lab-card__panel">
                            <div class="lab-card__content">
                                <span class="lab-card__meta">
                                    <span class="lab-card__category">Business Operations</span>
                                    <span class="lab-card__sep" aria-hidden="true"></span>
                                    <time class="lab-card__read" datetime="{{date createdAt "YYYY-MM-DD"}}">
                                        {{date createdAt "MMM D, YYYY"}}
                                    </time>
                                </span>
                                <h3 class="lab-card__title"><a href="{{url}}">{{title}}</a></h3>
                                {{#if postViewConfig.articleExcerpt}}
                                    <p class="lab-card__excerpt">{{postViewConfig.articleExcerpt}}</p>
                                {{/if}}
                                <a class="lab-card__cta" href="{{url}}">
                                    Read More
                                    <svg class="lab-card__cta-icon" viewBox="0 0 16 16" aria-hidden="true" focusable="false">
                                        <path fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" d="M3 8h10 M9 4l4 4-4 4" />
                                    </svg>
                                </a>
                            </div>
                        </div>
                    </li>
                {{/getPostsByTags}}

            </ul>

            <div class="lab-insights__dots" data-lab-dots aria-hidden="true"></div>
        </div>
    </section>

</main>

{{> footer}}
