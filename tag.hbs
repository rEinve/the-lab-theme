{{> head}}
{{> header}}

{{> blog-subnav}}
<main class="site-main archive-page blog-index">
    {{#tag}}
    <section class="archive-page__intro blog-index__intro">
        <div class="container">
            <div class="grid-12 blog-index__headline"
                <div class="md-col-4">
                    <h1 class="display-m archive-page__title">{{name}}</h1>
                </div>
                <div class="md-col-8">
                    <p class="lead archive-page__lead">
                        {{#if description}}
                            {{{description}}}
                        {{/if}}
                    </p>
                </div>
            </div>
        </div>
    </section>
    {{/tag}}

    {{#each posts}}
        {{#checkIf @index "==" 0}}
        <section class="blog-index__featured">
            <div class="container">
                <article class="blog-index__feature-card">
                    {{#featuredImage}}
                    <a class="blog-index__feature-media" href="{{../url}}">
                        <img src="{{url}}" alt="{{alt}}" />
                    </a>
                    {{/featuredImage}}
                    <div class="blog-index__feature-copy">
                        {{#if mainTag}}
                            <span class="blog-index__eyebrow">{{mainTag.name}}</span>
                        {{/if}}
                        <h2 class="blog-index__feature-title">
                            <a href="{{url}}">{{title}}</a>
                        </h2>
                        {{#if postViewConfig.articleExcerpt}}<p class="blog-index__feature-text">{{postViewConfig.articleExcerpt}}</p>{{/if}}
                        <a class="blog-index__feature-link" href="{{url}}" aria-label="Read featured article">
                            <span aria-hidden="true">→</span>
                        </a>
                    </div>
                </article>
            </div>
        </section>
        {{/checkIf}}
    {{/each}}

    <section class="blog-index__latest">
        <div class="surface-99">
            <div class="container">
                <div class="grid-12 archive-page__layout">
                    <div class="md-col-3 archive-page__panel">
                        <h3 class="headline-m">Topics</h3>
                        <hr>
                        <ul class="article-post__tags">
                            {{#each tags}}
                                {{#checkIf @index "<" 6}}
                                    <li><a class="article-post__tags" href="{{url}}">{{name}}</a></li>
                                {{/checkIf}}
                            {{/each}}
                        </ul>
                    </div>
                    <div class="md-col-9 archive-page__panel">
                        <h3 class="headline-m">Good Starting Points</h3>
                        <hr>
                        <ul class="article-post__tags">
                            {{#each posts}}
                                {{#checkIf @index "<" 3}}
                                    <li>
                                        <a class="archive-page__sidebar-link" href="{{url}}">{{title}}</a>
                                    </li>
                                {{/checkIf}}
                            {{/each}}
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="blog-index__latest" aria-labelledby="archive-list-title">
        <div class="container">
            <div class="archive-page__feed-heading">
                <span class="card-kicker">Browse</span>
                <h2 id="archive-list-title" class="headline-l">Posts in this topic</h2>
            </div>
            <hr>
            <div class="blog-index__latest-grid">
                {{#each posts}}
                    <article class="blog-index__story-card">
                        <a class="blog-index__story-link" href="{{url}}">
                            <div class="blog-index__story-meta">
                                {{#if mainTag}}<span>{{mainTag.name}}</span>{{/if}}
                                <time datetime="{{date createdAt "YYYY-MM-DD"}}">{{date createdAt "MMM D, YYYY"}}</time>
                            </div>
                            <h3 class="blog-index__story-title">{{title}}</h3>
                            {{#if postViewConfig.articleExcerpt}}<p class="blog-index__story-text">{{postViewConfig.articleExcerpt}}</p>{{/if}}
                            {{#featuredImage}}
                            <figure class="blog-index__story-thumb">
                                <img src="{{url}}" alt="{{alt}}" loading="lazy">
                            </figure>
                            {{/featuredImage}}
                        </a>
                    </article>
                {{/each}}
            </div>
            {{> pagination}}
        </div>
    </section>

</main>

{{> footer}}
