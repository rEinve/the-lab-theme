{{> head}}
{{> header}}

{{> blog-subnav}}

<main class="site-main archive-page blog-index">

    <section class="archive-page__intro blog-index__intro">
        <div class="container">
            <div class="grid-12 blog-index__headline">
                <div class="md-col-4">
                    <h1 class="display-m archive-page__title">All Topics</h1>
                </div>
                <div class="md-col-8">
                    <p class="lead archive-page__lead">
                        Browse all topics across the publication. Move through the tag archive to find writing by theme, focus area, or recurring idea.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <section class="blog-index__latest" aria-labelledby="tags-list-title">
        <div class="container">
            <div class="archive-page__feed-heading">
                <span class="card-kicker">Browse</span>
                <h2 id="tags-list-title" class="headline-l">All Topics</h2>
            </div>
            <hr>
            <div class="blog-index__latest-grid">
                {{#each tags}}
                    <article class="blog-index__story-card">
                        <a class="blog-index__story-link" href="{{url}}">
                            <div class="blog-index__story-meta">
                                <span>Topic</span>
                                <span>{{postsNumber}} post{{#checkIf postsNumber "!=" 1}}s{{/checkIf}}</span>
                            </div>
                            <h3 class="blog-index__story-title">{{name}}</h3>
                            {{#if description}}
                                <p class="blog-index__story-text">{{description}}</p>
                            {{/if}}
                        </a>
                    </article>
                {{/each}}
            </div>
        </div>
    </section>

</main>

{{> footer}}
