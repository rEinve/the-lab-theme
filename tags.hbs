{{> head}}
{{> header}}

<main class="site-main archive-page">
    <section class="section archive-page__intro">
        <div class="section-shell grid-12">
            <div class="col-full md-col-7 archive-page__intro-copy">
                <span class="card-kicker">Tags</span>
                <h1 class="display-m archive-page__title">Browse all topics across the publication.</h1>
                <p class="lead archive-page__lead">
                    Move through the tag archive to find writing by theme, focus area, or recurring idea.
                </p>
            </div>
        </div>
    </section>

    <section class="feed-wraper">
        <div class="section-shell">
            <div class="layout-grid-3">
                {{#each tags}}
                    <article class="home-story-card">
                        <div class="home-story-card__body stack--sm">
                            <span class="home-story-card__eyebrow">Topic</span>
                            <h2 class="headline-s home-story-card__title">
                                <a href="{{url}}">{{name}}</a>
                            </h2>
                            <p class="home-story-card__excerpt">
                                {{#if description}}
                                    {{description}}
                                {{else}}
                                    {{postsNumber}} post{{#checkIf postsNumber "!=" 1}}s{{/checkIf}} in this topic.
                                {{/if}}
                            </p>
                        </div>
                        <div class="home-story-card__footer">
                            <span class="home-story-card__tag">{{postsNumber}} posts</span>
                        </div>
                    </article>
                {{/each}}
            </div>
        </div>
    </section>
</main>

{{> footer}}
