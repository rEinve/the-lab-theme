<div class="article-share" data-share-group data-share-url="{{url}}" data-share-title="{{title}}">
    <span class="article-share__label">{{#if label}}{{label}}{{else}}Share{{/if}}</span>
    <div class="article-share__actions stack">
        <a class="article-share__button" data-share-platform="facebook" aria-label="Share on Facebook" title="Share on Facebook">
            <img class="article-share__icon" src="{{asset "images/facebook.svg"}}" alt="" aria-hidden="true">
            <span class="article-share__text">Facebook</span>
        </a>
        <a class="article-share__button" data-share-platform="x" aria-label="Share on X" title="Share on X">
            <img class="article-share__icon" src="{{asset "images/x.svg"}}" alt="" aria-hidden="true">
            <span class="article-share__text">X</span>
        </a>
        <a class="article-share__button" data-share-platform="linkedin" aria-label="Share on LinkedIn" title="Share on LinkedIn">
            <svg class="article-share__icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                <path d="M6.94 8.5H3.56V20h3.38V8.5ZM5.25 3A1.97 1.97 0 0 0 3.28 4.97c0 1.08.87 1.97 1.94 1.97h.03a1.97 1.97 0 1 0 0-3.94ZM20.72 13.02c0-3.09-1.65-4.52-3.86-4.52-1.78 0-2.58.98-3.02 1.67V8.5h-3.38c.04 1.11 0 11.5 0 11.5h3.38v-6.42c0-.34.02-.68.13-.92.27-.68.88-1.39 1.92-1.39 1.36 0 1.9 1.04 1.9 2.56V20H21c.04-.09.06-6.98.06-6.98h-.34Z"/>
            </svg>
            <span class="article-share__text">LinkedIn</span>
        </a>
        <a class="article-share__button" data-share-platform="whatsapp" aria-label="Share on WhatsApp" title="Share on WhatsApp">
            <svg class="article-share__icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                <path d="M20.52 3.45A11.83 11.83 0 0 0 12.07 0C5.56 0 .26 5.3.26 11.81c0 2.08.55 4.12 1.58 5.91L0 24l6.46-1.69a11.77 11.77 0 0 0 5.61 1.43h.01c6.51 0 11.81-5.3 11.81-11.81 0-3.15-1.23-6.1-3.47-8.48Zm-8.45 18.3h-.01a9.78 9.78 0 0 1-4.98-1.36l-.36-.21-3.83 1 1.02-3.73-.23-.38a9.78 9.78 0 0 1-1.51-5.26C2.17 6.39 6.63 1.93 12.07 1.93a9.8 9.8 0 0 1 6.97 2.89 9.76 9.76 0 0 1 2.88 6.96c0 5.45-4.45 9.97-9.85 9.97Zm5.46-7.44c-.3-.15-1.77-.87-2.05-.96-.27-.1-.47-.15-.66.15-.2.3-.76.96-.94 1.16-.17.2-.35.22-.65.08-.3-.15-1.27-.47-2.42-1.5-.89-.79-1.49-1.77-1.67-2.07-.18-.3-.02-.46.13-.61.14-.14.3-.35.45-.52.15-.17.2-.3.3-.5.1-.2.05-.38-.03-.53-.07-.15-.66-1.58-.9-2.17-.24-.57-.48-.49-.66-.5h-.56c-.2 0-.52.07-.79.37-.28.3-1.05 1.03-1.05 2.51 0 1.48 1.08 2.92 1.23 3.12.15.2 2.12 3.24 5.13 4.54.72.31 1.28.49 1.72.63.72.23 1.37.2 1.88.12.58-.09 1.77-.72 2.02-1.42.25-.7.25-1.3.17-1.42-.08-.12-.28-.2-.58-.35Z"/>
            </svg>
            <span class="article-share__text">WhatsApp</span>
        </a>
        <button class="article-share__button" type="button" data-share-copy aria-label="Copy article link" title="Copy article link">
            <svg class="article-share__icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                <path d="M10.59 13.41a1 1 0 0 0 1.41 1.41l4.24-4.24a3 3 0 0 0-4.24-4.24l-1.88 1.88a1 1 0 1 0 1.41 1.41l1.88-1.88a1 1 0 0 1 1.41 1.41L10.59 13.4ZM13.41 10.59A1 1 0 0 0 12 9.17l-4.24 4.24a3 3 0 0 0 4.24 4.24l1.88-1.88a1 1 0 1 0-1.41-1.41l-1.88 1.88a1 1 0 0 1-1.41-1.41l4.24-4.24Z"/>
            </svg>
            <span class="article-share__text">Copy link</span>
        </button>
    </div>
    <p class="article-share__status" data-share-status aria-live="polite"></p>
</div>
