{{#if @pagination}}
    <nav class="section-shell" aria-label="Pagination">
        <ul class="pagination__list">
            {{#if @pagination.previousPage}}
                <li>
                    <a class="pagination__link" href="{{pageUrl @pagination.context @pagination.previousPage}}">Prev</a>
                </li>
            {{/if}}

            {{#each @pagination.pages}}
                <li>
                    {{#isCurrentPage @pagination.currentPage this}}
                        <span class="pagination__link" aria-current="page">{{this}}</span>
                    {{else}}
                        <a class="pagination__link" href="{{pageUrl @pagination.context this}}">{{this}}</a>
                    {{/isCurrentPage}}
                </li>
            {{/each}}

            {{#if @pagination.nextPage}}
                <li>
                    <a class="pagination__link" href="{{pageUrl @pagination.context @pagination.nextPage}}">Next</a>
                </li>
            {{/if}}
        </ul>
    </nav>
{{/if}}
