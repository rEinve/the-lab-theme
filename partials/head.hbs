<!DOCTYPE html>
<html lang="{{@website.language}}">

<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <!-- Geo meta tags: Tanzania / Dodoma -->
<meta name="geo.region" content="TZ" />
<meta name="geo.placename" content="Dodoma, Tanzania" />
<meta name="ICBM" content="-6.1722, 35.7395" />
<meta property="og:site_name" content="IntelliWebLab" />
<meta property="og:type" content="website" />
<meta property="og:locale" content="en_TZ" />
<!-- LocalBusiness schema -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "IntelliWebLab",
  "description": "Web design, WhatsApp chatbots, n8n automation and AI agent development for businesses in Dodoma and across Tanzania.",
  "url": "https://intelliweblab.com",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Dodoma",
    "addressRegion": "Dodoma",
    "addressCountry": "TZ"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": -6.1722,
    "longitude": 35.7395
  },
  "areaServed": "Tanzania",
  "knowsAbout": ["Web Design", "WhatsApp Chatbot", "n8n Automation", "AI Agents", "Business Automation"]
}
</script>
    <title>{{metaTitleRaw}}</title>
    {{metaDescription}}
    {{metaRobots}}
    {{canonicalLink}}
    {{{socialMetaTags}}}
    {{#if @pagination}}
    {{#if @pagination.previousPage}}
    <link rel="prev" href="{{pageUrl @pagination.context @pagination.previousPage}}">
    {{/if}} 
    {{#if @pagination.nextPage}}
    <link rel="next" href="{{pageUrl @pagination.context @pagination.nextPage}}">
    {{/if}}
    {{/if}}
    <link rel="icon" href="{{asset "images/logo-icon.svg"}}" type="image/svg+xml">
    <link rel="stylesheet" href="{{css "main.css"}}">
    {{{publiiHead}}}
    {{#if @config.custom.googleAnalyticsId}}
    <script>
        (function () {
            var measurementId = '{{@config.custom.googleAnalyticsId}}';
            var allowedHostsRaw = '{{@config.custom.googleAnalyticsHosts}}';
            var allowedHosts = allowedHostsRaw
                .split(',')
                .map(function (item) {
                    return item.trim().toLowerCase();
                })
                .filter(Boolean);
            var hostname = (window.location.hostname || '').toLowerCase();
            var protocol = window.location.protocol;
            var isPreviewProtocol = protocol === 'file:';
            var isLocalTestHost = hostname === 'localhost' || hostname === '127.0.0.1' || hostname === '::1';
            var isAllowedHost = allowedHosts.length ? allowedHosts.indexOf(hostname) > -1 : !isLocalTestHost && !isPreviewProtocol;

            if (!measurementId || isPreviewProtocol || isLocalTestHost || !isAllowedHost) {
                return;
            }

            var script = document.createElement('script');
            script.async = true;
            script.src = 'https://www.googletagmanager.com/gtag/js?id=' + encodeURIComponent(measurementId);
            document.head.appendChild(script);

            window.dataLayer = window.dataLayer || [];
            window.gtag = window.gtag || function () {
                window.dataLayer.push(arguments);
            };

            window.gtag('js', new Date());
            window.gtag('config', measurementId);
        })();
    </script>
    {{/if}}
</head>

<body>